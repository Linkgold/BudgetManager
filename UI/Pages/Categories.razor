@page "/categories"
@attribute [Authorize]
@inherits BasePage

<div class="container mt-3">
    <!-- 🔹 Título y botón de acción -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <h4 class="mb-0 page-title">📂 Categorías</h4>
        <button class="btn btn-primary btn-sm" @onclick="OpenCreateModal">
            ➕ Nueva Categoría
        </button>
    </div>

    <!-- 🔹 Contenedort de Modal -->
    <div class="table-card-wrapper">
        <!-- 🔹 Filtros y búsqueda -->
        <div class="card filter-card mb-3">
            <div class="card-body d-flex flex-wrap align-items-center gap-2">
                <div class="flex-grow-1" style="min-width: 200px;">
                    <input type="text" class="form-control form-control-sm" placeholder="🔍 Buscar categoría..." @bind="searchTerm" @bind:event="oninput" />
                </div>
            </div>
        </div>
        <!-- Modal para crear/editar/eliminar categoría -->
        <Modal Title="@GetModalTitle()"
               IsVisible="@isModalOpen"
               IsDeleteMode="@isDeleteMode"
               OnSave="@SaveCategory"
               OnClose="@CloseModal"
               SaveButtonText="@GetSaveButtonText()"
               SaveButtonClass="@GetSaveButtonClass()">
            <div class="form-group">
                <label class="form-label">Nombre</label>
                <input type="text" class="form-control" @bind="categoryForm.Name" disabled="@isDeleteMode" placeholder="Ej. Alimentación" />
            </div>
            <div class="form-group mt-2">
                <label class="form-label">Descripción</label>
                <input type="text" class="form-control" @bind="categoryForm.Description" disabled="@isDeleteMode" placeholder="Ej. Gastos de comida" />
            </div>
        </Modal>
    
        <!-- 🔹 Tabla de categorías -->
        <div class="card table-card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="data-table table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="text-start">Nombre</th>
                                <th class="text-start">Descripción</th>
                                <th class="text-end" style="width: 120px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (filteredCategories.Any())
                            {
                                @foreach (var category in filteredCategories)
                                {
                                    <tr>
                                        <td class="text-start">@category.Name</td>
                                        <td class="text-start">@category.Description</td>
                                        <td class="text-end">
                                            <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => OpenEditModal(category)">
                                                ✏️
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteCategory(category.Id)">
                                                🗑️
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-3">
                                        No hay categorías que coincidan con los filtros.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted small">
                Mostrando @filteredCategories.Count() de @categories.Count() categorías
            </div>
        </div>
    </div>
</div>