@page "/"
@attribute [Authorize]
@inherits BasePage

<div class="container mt-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <h4 class="mb-0 dashboard-title">📊 Resumen Anual @_currentYear</h4>
        <a href="/monthly" class="btn btn-outline-primary btn-sm dashboard-btn">📅 Ver mes actual</a>
    </div>

    <div class="card dashboard-card">
        <div class="card-header dashboard-card-header py-2">
            <small class="fw-bold">📊 Presupuestos vs Gastos reales por categoría</small>
        </div>
        <div class="card-body p-1">
            <div class="table-wrapper">
                <table class="data-table table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Mes</th>
                            @foreach (var categoria in _categorias)
                            {
                                <th class="text-center">@categoria</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mes in _meses)
                        {
                            <tr @onclick="() => NavigateToMonth(mes.Nombre)" title="Ver detalle de @mes.Nombre">
                                <td><span class="fw-semibold">@mes.Nombre</span></td>
                                @foreach (var categoria in _categorias)
                                {
                                    var valor = mes.ObtenerValor(categoria);
                                    <td class="category-cell text-center">
                                        @if (valor.TieneDatos)
                                        {
                                            <span class="fw-bold @(valor.Diferencia >= 0 ? "text-success" : "text-danger")">
                                                @FormatCurrency(valor.Gasto)
                                            </span>
                                            <span class="text-muted">/</span>
                                            <span class="fw-bold">@FormatCurrency(valor.Presupuesto)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted" style="font-size: 0.6rem;">—</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>