@page "/"
@attribute [Authorize]
@using UI.Shared
@inherits BasePage

<div class="container mt-4">
    <h1 class="mb-4">📊 Resumen de @_currentMonth</h1>

    <!-- Tarjetas de resumen -->
    <div class="row">
        <div class="col-md-3 mb-3">
            <div class="card summary-card income">
                <div class="card-body">
                    <div class="label">Saldo</div>
                    <div class="number">@_saldo.ToString("C", CultureInfo.GetCultureInfo("es-ES"))</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card summary-card expense">
                <div class="card-body">
                    <div class="label">Gastos</div>
                    <div class="number text-danger">-@_gastos.ToString("C", CultureInfo.GetCultureInfo("es-ES"))</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card summary-card income">
                <div class="card-body">
                    <div class="label">Ingresos</div>
                    <div class="number text-success">+@_ingresos.ToString("C", CultureInfo.GetCultureInfo("es-ES"))</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card summary-card">
                <div class="card-body">
                    <div class="label">Presupuesto</div>
                    <div class="number">@_presupuesto.ToString("C", CultureInfo.GetCultureInfo("es-ES"))</div>
                    <small>Restante: @_restante.ToString("C", CultureInfo.GetCultureInfo("es-ES"))</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Gastos por categoría y últimos movimientos -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">📈 Gastos por categoría</div>
                <div class="card-body">
                    @if (_categorias.Any())
                    {
                        <ul class="list-group">
                            @foreach (var categoria in _categorias)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>@categoria.Nombre</span>
                                    <span class="badge bg-primary rounded-pill">@categoria.Total.ToString("C", CultureInfo.GetCultureInfo("es-ES"))</span>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No hay datos de categorías.</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">📋 Últimos movimientos</div>
                <div class="card-body">
                    @if (_ultimosMovimientos.Any())
                    {
                        <table class="table table-striped table-sm">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Concepto</th>
                                    <th class="text-end">Importe</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var movimiento in _ultimosMovimientos)
                                {
                                    <tr>
                                        <td>@movimiento.Fecha.ToShortDateString()</td>
                                        <td>@movimiento.Concepto</td>
                                        <td class="text-end @(movimiento.Tipo == "Ingreso" ? "text-success" : "text-danger")">
                                            @movimiento.Importe.ToString("C", CultureInfo.GetCultureInfo("es-ES"))
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">No hay movimientos recientes.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _currentMonth = DateTime.Now.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-ES"));
    private decimal _saldo = 450.00m;
    private decimal _gastos = 750.00m;
    private decimal _ingresos = 1200.00m;
    private decimal _presupuesto = 500.00m;
    private decimal _restante = 250.00m;

    private List<CategoriaGasto> _categorias = new()
    {
        new CategoriaGasto { Nombre = "Alimentación", Total = 45.75m },
        new CategoriaGasto { Nombre = "Transporte", Total = 50.00m },
        new CategoriaGasto { Nombre = "Ocio", Total = 30.00m },
        new CategoriaGasto { Nombre = "Vivienda", Total = 75.00m }
    };

    private List<Movimiento> _ultimosMovimientos = new()
    {
        new Movimiento { Fecha = new DateTime(2024, 7, 15), Concepto = "Supermercado", Importe = -45.75m, Tipo = "Gasto" },
        new Movimiento { Fecha = new DateTime(2024, 7, 14), Concepto = "Gasolina", Importe = -50.00m, Tipo = "Gasto" },
        new Movimiento { Fecha = new DateTime(2024, 7, 12), Concepto = "Salario", Importe = 1200.00m, Tipo = "Ingreso" },
        new Movimiento { Fecha = new DateTime(2024, 7, 10), Concepto = "Netflix", Importe = -15.99m, Tipo = "Gasto" }
    };

    private class CategoriaGasto
    {
        public string Nombre { get; set; } = string.Empty;
        public decimal Total { get; set; }
    }

    private class Movimiento
    {
        public DateTime Fecha { get; set; }
        public string Concepto { get; set; } = string.Empty;
        public decimal Importe { get; set; }
        public string Tipo { get; set; } = string.Empty;
    }
}