@page "/budgets"
@attribute [Authorize]
@inherits BasePage

<div class="container mt-3">
    <!-- Título y acciones -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <h4 class="mb-0 page-title">📊 Presupuestos</h4>
        <div>
            <button class="btn btn-primary btn-sm me-2" @onclick="OpenCreateModal">
                ➕ Nuevo Presupuesto
            </button>
        </div>
    </div>

    <!-- Filtros -->
    <!-- 🔹 Contenedort de Modal -->
    <div class="table-card-wrapper-budget">
        <div class="card filter-card mb-3">
            <div class="card-body d-flex flex-wrap align-items-center gap-2">
                <div class="flex-grow-1" style="min-width: 150px;">
                    <input type="text" class="form-control form-control-sm"
                           placeholder="🔍 Buscar categoría..."
                           @bind="searchTerm"
                           @bind:event="oninput" />
                </div>
                <div style="min-width: 100px;">
                    <select class="form-control form-control-sm" @bind="selectedYear">
                        @foreach (var year in _years)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <!-- Modal para crear/editar presupuestos -->
        <Modal Title="@GetModalTitle()"
                IsVisible="@isModalOpen"
                IsDeleteMode="@isDeleteMode"
                OnSave="@SaveBudget"
                OnClose="@CloseModal"
                SaveButtonText="@GetSaveButtonText()"
                SaveButtonClass="@GetSaveButtonClass()">

            <!-- 1. Selección de Año y Categoría -->
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Año</label>
                        <select class="form-control" @bind="budgetForm.Year">
                            @foreach (var year in _years)
                            {
                                <option value="@year">@year</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Categoría</label>
                        <select class="form-control" @bind="budgetForm.CategoryId">
                            <option value="0">Selecciona una categoría...</option>
                            @foreach (var category in _allCategories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- 2. Importe por defecto y acción "Aplicar a todos" -->
            <div class="row mt-2">
                <div class="col-md-8">
                    <div class="form-group">
                        <label class="form-label">Importe (aplicar a todos)</label>
                        <input type="number" class="form-control" @bind="budgetForm.Amount" step="0.01" min="0" placeholder="0.00" />
                    </div>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-outline-primary btn-sm w-100" @onclick="ApplyAmountToAllMonths">
                        📋 Aplicar a todos los meses
                    </button>
                </div>
            </div>

            <!-- 3. Tabla de meses (con scroll si es necesario) -->
            <div class="mt-3" style="max-height: 300px; overflow-y: auto;">
                <table class="table table-sm table-borderless budget-month-table mb-0">
                    <thead>
                        <tr>
                            <th style="width: 30%;">Mes</th>
                            <th style="width: 70%;">Importe</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var month in _months)
                        {
                            <tr>
                                <td><span class="fw-semibold">@month.Name</span></td>
                                <td>
                                    <input type="number" class="form-control form-control-sm"
                                            step="0.01" min="0" placeholder="0.00"
                                            @bind="monthlyAmounts[month.Value]" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- 4. Resumen rápido -->
            <div class="mt-2 budget-total-label text-muted small">
                Total presupuesto anual: <span class="fw-bold">@CalculateTotalAnnualBudget().ToString("C", new System.Globalization.CultureInfo("es-ES"))</span>
            </div>

        </Modal>


        <!-- Tabla de presupuestos (vista anual) -->
        <div class="card table-card">
            <div class="card-body p-0">
                <div class="table-responsive" style="overflow-x: auto; overflow-y: visible;">
                    <table class="budgets-table table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="text-start">Categoría</th>
                                @foreach (var month in _months)
                                {
                                    <th class="text-center" style="min-width: 50px;">@month.ShortName</th>
                                }
                                <th class="text-end" style="min-width: 80px;">Total</th>
                                <th class="text-end" style="min-width: 100px; width: 100px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (filteredCategories.Any())
                            {
                                @foreach (var category in filteredCategories)
                                {
                                    <tr>
                                        <td class="text-start">@category.Name</td>
                                        @foreach (var month in _months)
                                        {
                                            var amount = GetBudgetAmount(category.Id, month.Value, selectedYear);
                                            <td class="text-center">@(amount > 0 ? amount.ToString("C", new System.Globalization.CultureInfo("es-ES")) : "—")</td>
                                        }
                                        <td class="text-end">@GetCategoryTotal(category.Id, selectedYear).ToString("C", new System.Globalization.CultureInfo("es-ES"))</td>
                                        <td class="text-end">
                                            <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => OpenEditModal(category.Id, selectedYear)">
                                                ✏️
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteCategoryBudgets(category.Id, selectedYear)">
                                                🗑️
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@(_months.Count + 3)" class="text-center text-muted py-3">
                                        No hay presupuestos para el año seleccionado.
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-secondary fw-bold">
                                <td class="text-start">TOTAL</td>
                                @foreach (var month in _months)
                                {
                                    <td class="text-center">@GetMonthTotal(month.Value, selectedYear).ToString("C", new System.Globalization.CultureInfo("es-ES"))</td>
                                }
                                <td class="text-end">@GetTotal(selectedYear).ToString("C", new System.Globalization.CultureInfo("es-ES"))</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted small">
                Mostrando @filteredCategories.Count() categorías para el año @selectedYear
            </div>
        </div>
    </div>
</div>