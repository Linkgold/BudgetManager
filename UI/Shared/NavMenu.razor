@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <span style="font-weight:700; color:#3498DB;">💰</span> Budget Manager
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-home" aria-hidden="true"></span> Inicio
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="categorias">
                <span class="oi oi-tag" aria-hidden="true"></span> Categorías
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="gastos">
                <span class="oi oi-dollar" aria-hidden="true"></span> Gastos
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="presupuestos">
                <span class="oi oi-graph" aria-hidden="true"></span> Presupuestos
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="perfil">
                <span class="oi oi-person" aria-hidden="true"></span> Perfil
            </NavLink>
        </div>
        <div class="nav-item px-3" style="border-top: 1px solid rgba(255,255,255,0.1); margin-top: 8px; padding-top: 8px;">
            <a class="nav-link" href="#" @onclick="Logout" style="color: #E74C3C !important;">
                <span class="oi oi-account-logout" aria-hidden="true"></span> Cerrar sesión
            </a>
        </div>
        @if (!AuthService.IsAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="register">
                    <span class="oi oi-person" aria-hidden="true"></span> Registrarse
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool _collapseNavMenu = true;

    private string? NavMenuCssClass => _collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        _collapseNavMenu = !_collapseNavMenu;
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login", true);
    }
}