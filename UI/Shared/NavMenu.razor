@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IThemeService ThemeService

<div class="nav-menu-wrapper">
    <div class="top-row ps-3 nav-top-bar">
        <div class="container-fluid d-flex justify-content-start align-items-center">
            <button title="Navigation menu" class="navbar-toggler me-2" @onclick="ToggleNavMenu">
                <span class="navbar-toggler-icon-custom">☰</span>
            </button>
            <span class="navbar-brand">
                <span style="font-weight:700; color:var(--color-accent);">💰</span> Budget Manager
            </span>
        </div>
    </div>

    @if (!_collapseNavMenu)
    {
        <!-- 🔥 Overlay que captura clics fuera del menú -->
        <div class="nav-overlay" @onclick="CloseMenu"></div>

        <div class="nav-dropdown">
            <nav class="flex-column">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseMenu">
                        <span class="oi oi-home" aria-hidden="true"></span> Inicio
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="categorias" @onclick="CloseMenu">
                        <span class="oi oi-tag" aria-hidden="true"></span> Categorías
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="gastos" @onclick="CloseMenu">
                        <span class="oi oi-dollar" aria-hidden="true"></span> Gastos
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="presupuestos" @onclick="CloseMenu">
                        <span class="oi oi-graph" aria-hidden="true"></span> Presupuestos
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="perfil" @onclick="CloseMenu">
                        <span class="oi oi-person" aria-hidden="true"></span> Perfil
                    </NavLink>
                </div>

                <div class="nav-divider"></div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="#" @onclick:preventDefault @onclick="ToggleTheme">
                        <span class="oi oi-sun" aria-hidden="true"></span>
                        @(ThemeService.IsDark ? "☀️ Claro" : "🌙 Oscuro")
                    </a>
                </div>

                <div class="nav-divider"></div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="#" @onclick="Logout" style="color: #E74C3C !important;">
                        <span class="oi oi-account-logout" aria-hidden="true"></span> Cerrar sesión
                    </a>
                </div>
            </nav>
        </div>
    }
</div>

@code {
    private bool _collapseNavMenu = true;

    private void ToggleNavMenu()
    {
        _collapseNavMenu = !_collapseNavMenu;
    }

    private void CloseMenu()
    {
        _collapseNavMenu = true;
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login", true);
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleTheme();
    }
}